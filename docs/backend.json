
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Information about a user, including their assigned academic role and managed branches.",
      "type": "object",
      "properties": {
        "displayName": {
          "type": "string"
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "role": {
          "type": "string",
          "enum": [
            "bos_convenor",
            "dean_faculty",
            "dean_academics",
            "admin"
          ]
        },
        "photoURL": {
          "type": "string"
        },
        "managedBranches": {
          "type": "array",
          "description": "List of program branches this user is authorized to manage.",
          "items": {
            "type": "object",
            "properties": {
              "programId": { "type": "string" },
              "branch": { "type": "string" }
            }
          }
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "email",
        "role"
      ]
    },
    "Program": {
      "title": "Program",
      "description": "Definition of an academic program and its associated NEP 2020 credit rules and branches.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "code": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "totalSemesters": {
          "type": "number"
        },
        "level": {
          "type": "string",
          "enum": [
            "UG",
            "PG",
            "Diploma",
            "Certificate"
          ]
        },
        "branches": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of specializations or branches within this program."
        },
        "rules": {
          "type": "object",
          "properties": {
            "dscMin": { "type": "number" },
            "dscMax": { "type": "number" },
            "experientialMin": { "type": "number" },
            "experientialMax": { "type": "number" },
            "dseMin": { "type": "number" },
            "dseMax": { "type": "number" },
            "ofeMin": { "type": "number" },
            "ofeMax": { "type": "number" },
            "totalRequired": { "type": "number" }
          }
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "name",
        "code",
        "level",
        "totalSemesters"
      ]
    },
    "Scheme": {
      "title": "Scheme",
      "description": "An academic scheme for a specific program, branch, and batch.",
      "type": "object",
      "properties": {
        "programId": { "type": "string" },
        "branch": { "type": "string" },
        "batchYear": { "type": "string" },
        "status": { "type": "string", "enum": ["Draft", "Pending Dean", "Pending Academics", "Approved"] },
        "version": { "type": "string" },
        "createdBy": { "type": "string" },
        "hasMultipleExits": { "type": "boolean" },
        "exitOptions": { "type": "array", "items": { "type": "string" } },
        "abcEnabled": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["programId", "batchYear", "status"]
    },
    "Syllabus": {
      "title": "Syllabus",
      "description": "Details of a specific subject within a scheme, including L-T-P credits.",
      "type": "object",
      "properties": {
        "subjectCode": { "type": "string" },
        "title": { "type": "string" },
        "type": { "type": "string" },
        "lectureCredits": { "type": "number" },
        "tutorialCredits": { "type": "number" },
        "practicalCredits": { "type": "number" },
        "credits": { "type": "number" },
        "semester": { "type": "number" },
        "creditCategory": { "type": "string" },
        "prerequisites": { "type": "array", "items": { "type": "string" } },
        "courseOutcomes": { "type": "array", "items": { "type": "string" } },
        "programOutcomes": { "type": "array", "items": { "type": "string" } },
        "resources": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["subjectCode", "title", "credits", "semester", "creditCategory"]
    }
  },
  "auth": {
    "providers": [
      "password",
      "github"
    ]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Stores user profiles and their associated roles and managed branches."
    },
    "/programs/{programId}": {
      "schema": "Program",
      "description": "Stores program definitions and credit compliance rules."
    },
    "/schemes/{schemeId}": {
      "schema": "Scheme",
      "description": "Stores high-level scheme definitions."
    },
    "/schemes/{schemeId}/syllabi/{syllabusId}": {
      "schema": "Syllabus",
      "description": "Stores syllabi for subjects within a scheme."
    }
  }
}


{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Information about a user, including their assigned academic role.",
      "type": "object",
      "properties": {
        "displayName": {
          "type": "string"
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "role": {
          "type": "string",
          "enum": [
            "bos_convenor",
            "dean_faculty",
            "dean_academics",
            "admin"
          ]
        },
        "photoURL": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "email",
        "role"
      ]
    }
  },
  "auth": {
    "providers": [
      "password"
    ]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Stores user profiles and their associated roles."
    }
  }
}

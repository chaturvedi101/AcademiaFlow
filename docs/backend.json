{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Information about a user, including their assigned academic role, managed branches, or faculty assignment.",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": {
          "type": "string",
          "enum": ["bos_convenor", "bos_member", "dean_faculty", "dean_academic", "admin", "monitor", "committee_convenor"]
        },
        "faculty": {
          "type": "string",
          "enum": [
            "Faculty of Built Environment",
            "Faculty of Materials Science and Engineering",
            "Faculty of Mechanical and Applied Engineering",
            "Faculty of Computer Science and Communication Engineering",
            "Faculty of Energy and Environment Engineering",
            "Faculty of Management Studies",
            "Faculty of Arts",
            "Faculty of Sciences",
            "BTECH (Common BOS)",
            "BBA (Common BOS)",
            "Course Committee - Mathematics",
            "Course Committee - Physics",
            "Course Committee - Chemistry",
            "Course Committee - Humanities",
            "Course Committee - Basic Sciences"
          ]
        },
        "managedBranches": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "programId": { "type": "string" },
              "branch": { "type": "string" },
              "role": { "type": "string", "enum": ["bos_convenor", "bos_member"] }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role"]
    },
    "Program": {
      "title": "Program",
      "description": "Definition of an academic program, its faculty association, and credit compliance rules.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "code": { "type": "string" },
        "faculty": { "type": "string" },
        "description": { "type": "string" },
        "totalSemesters": { "type": "number" },
        "level": { "type": "string", "enum": ["UG", "PG", "Diploma", "Certificate"] },
        "branches": { "type": "array", "items": { "type": "string" } },
        "branchPrefixes": { "type": "object" },
        "rules": {
          "type": "object",
          "properties": {
            "dscMin": { "type": "number" },
            "dscMax": { "type": "number" },
            "totalRequired": { "type": "number" }
          }
        }
      },
      "required": ["name", "code", "faculty", "level"]
    },
    "Scheme": {
      "title": "Scheme",
      "description": "Composite definition of a branch-specific or common course scheme.",
      "type": "object",
      "properties": {
        "schemeCode": { "type": "string" },
        "programId": { "type": "string" },
        "branch": { "type": "string" },
        "batchYear": { "type": "string" },
        "status": { "type": "string" },
        "version": { "type": "string" },
        "isVerticalPool": { "type": "boolean" },
        "isCommitteePool": { "type": "boolean" }
      },
      "required": ["schemeCode", "programId", "batchYear", "status"]
    }
  },
  "auth": {
    "providers": ["password", "github"]
  },
  "firestore": {
    "/users/{userId}": { "schema": "UserProfile", "description": "User profiles and roles." },
    "/programs/{programId}": { "schema": "Program", "description": "Program definitions." },
    "/schemes/{schemeId}": { "schema": "Scheme", "description": "Scheme definitions." },
    "/schemes/{schemeId}/syllabi/{syllabusId}": { "schema": "Syllabus", "description": "Subject syllabi." }
  }
}